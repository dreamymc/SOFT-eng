# -----------------------------------------------------------------------------
# Tungal Flower Shop - Local XAMPP Environment Template
# -----------------------------------------------------------------------------
# Copy this file into the Laravel app folder:
#
#   copy ..\.env.example .env
#
# Run that command from:
#
#   Tungal_Flower_Shop-master
#
# This template is set up for local XAMPP/MySQL development.

APP_NAME="Tungal Flower Shop"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Manila

# -----------------------------------------------------------------------------
# Cloudinary
# -----------------------------------------------------------------------------
# Required for product images, employee profile images, and delivery proof images.
# Get this value from the Cloudinary dashboard.
#
# Format:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# If left as the placeholder below, image uploads will fail.

CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# XAMPP MySQL Database
# -----------------------------------------------------------------------------
# Default XAMPP values:
# - Host: 127.0.0.1
# - Port: 3306
# - Username: root
# - Password: empty
#
# Create this database first in phpMyAdmin:
#
#   tungal_flowershop

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tungal_flowershop
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Local App Services
# -----------------------------------------------------------------------------
# Use file cache/session locally so the app can boot before database migrations.
# You may switch these to "database" after running migrations if wanted.

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Redis / Memcached
# -----------------------------------------------------------------------------
# Not required for normal local XAMPP setup.

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
# Local default logs mail instead of sending real emails.

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# AWS/S3
# -----------------------------------------------------------------------------
# Not used by default. Images are uploaded through Cloudinary.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
